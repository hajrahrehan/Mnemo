# ---- Groq (LLM) ---------------------------------------------------------
# Sign up at https://console.groq.com → create API key (free, no credit card).
GROQ_API_KEY=

# Model used for flashcard generation. Recommended defaults:
#   llama-3.3-70b-versatile (best quality)
#   llama-3.1-8b-instant    (cheapest / fastest)
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Supabase (Auth + Postgres + Storage) -------------------------------
# Sign up at https://supabase.com → create project → Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role key — used only in server routes that need to bypass RLS.
# NEVER expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=
